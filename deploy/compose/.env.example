# =============================================================================
# outline-gate — скопируйте в .env и заполните:
#   cp .env.example .env
#   ./configure.sh   # интерактивно, либо отредактируйте .env вручную
# =============================================================================

# --- Обязательно: один из вариантов ключа Outline (ss://... или ssconf://...) ---
# Вариант 1 (удобно): ключ прямо в .env (файл .env в .gitignore)
# ssconf:// будет раскрыт в ss:// при каждом Connect
OUTLINE_ACCESS_KEY=

# Вариант 2: путь к файлу с ключом ВНУТРИ контейнера
# (файл с хоста монтируется в compose; см. OUTLINE_KEY_HOST_PATH)
# OUTLINE_ACCESS_KEY_FILE=/run/secrets/outline_key
# OUTLINE_KEY_HOST_PATH=./secrets/outline_key.txt

# --- Режим split-tunnel ---
# exclude — весь трафик через туннель, кроме bypass
# include — только адреса из TUNNEL_* через туннель
ROUTING_MODE=exclude

# Доп. исключения (через запятую) и/или файлы в ./config/
BYPASS_CIDRS=
BYPASS_CIDRS_FILE=/config/bypass.txt

# Цели для include-режима (обязательны при ROUTING_MODE=include)
TUNNEL_CIDRS=
TUNNEL_CIDRS_FILE=/config/tunnel.txt

# Поведение для «не в списке» в include: direct | drop
DIRECT_POLICY=direct

# L3-шлюз (nftables). Для bridge-compose обычно false; для host-compose — true
GATEWAY_ENABLE=false

# Интерфейс в сторону LAN (пусто = masquerade на все)
# LAN_INTERFACE=eth0

# Слушатели
SOCKS_LISTEN=0.0.0.0:1080
HEALTH_LISTEN=0.0.0.0:8080
TRANSPROXY_LISTEN=127.0.0.1:12345

# Логи: debug | info | warn | error ; format: text | json
LOG_LEVEL=info
LOG_FORMAT=text

# Переподключение к Outline
RECONNECT_BASE_DELAY=1s
RECONNECT_MAX_DELAY=60s

# DNS (v1: в основном для документации / будущих хуков)
DNS_MODE=system
# DNS_SERVERS=1.1.1.1,8.8.8.8

# Порты на хосте (только bridge-профиль)
HOST_SOCKS_PORT=1080
HOST_HEALTH_PORT=8080

# Тег образа
IMAGE_TAG=outline-gate:local
