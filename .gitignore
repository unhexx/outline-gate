# Binaries
/bin/
/dist/
/outline-gate
*.exe
*.test

# Secrets & local env (.env never committed; key file stub is tracked as template)
.env
*.key
# Local overrides of the compose key file (if you replace the stub with a real key,
# keep it untracked by using secrets/outline_key.local.txt + OUTLINE_KEY_HOST_PATH)
deploy/compose/secrets/outline_key.local.txt

# IDE / OS
.idea/
.vscode/
*.swp
.DS_Store

# Coverage
coverage.out
coverage.html

# Go
vendor/

# Real compose secrets (template stub may still be tracked historically)
deploy/compose/secrets/outline_key.txt
!deploy/compose/secrets/.gitkeep

# Local secret overrides (any *local* key files under compose)
deploy/compose/secrets/*local*
deploy/compose/.env

# Accidental nested clone / workdir
/outline-gate/
